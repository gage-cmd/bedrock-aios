# Copy to .env and fill in real values. Never commit .env.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Discrete fields for the `pg` node client -- its connection-string parser
# breaks on special characters in some passwords, so anything connecting via
# `pg` (rather than psql) should use these fields directly. This is the
# TRANSACTION pooler (port 6543): what every app query pool uses.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# "stub" (default) uses StubSmsClient -- no real Twilio account needed.
# Switch to "twilio" once a live account exists and the vars below are set.
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

ANTHROPIC_API_KEY=

# Model for the Command Center orchestrator (core/orchestrator). Never
# hardcoded at the call site -- read from this var, defaulting to
# claude-sonnet-5 if unset.
ORCHESTRATOR_MODEL=claude-sonnet-5

# Model for the Executive Oversight weekly report engine
# (core/executive-oversight). Independent from ORCHESTRATOR_MODEL so the two
# can be tuned separately; never hardcoded at the call site, defaulting to
# claude-sonnet-5 if unset.
REPORT_MODEL=claude-sonnet-5

# Optional overrides for the Executive Oversight report engine -- safe to
# leave unset, defaults shown.
# REPORT_MODULE_TIMEOUT_MS=10000
# REPORT_SCHEDULE_CRON=0 8 * * 1
# REPORT_SCHEDULE_TZ=UTC
# REPORT_SCHEDULER_DISABLED=false

# pg-boss (the weekly report scheduler) needs SESSION-level Postgres features
# that Supabase's transaction pooler above does not support, so it connects
# separately on the SESSION-mode pooler (same host/creds, port 5432).
# REPORT_QUEUE_DB_PORT=5432
# REPORT_QUEUE_DATABASE_URL=

# Invite delivery for the Onboarding Console: "supabase" sends real invite
# emails through GoTrue's admin endpoint (requires SUPABASE_SERVICE_ROLE_KEY);
# anything else uses the stub (no email, fabricated auth user id).
INVITE_PROVIDER="stub"

# Public URL of apps/dashboard. Used to build the redirect_to for invite
# emails, so the link lands on /set-password instead of GoTrue's default
# Site URL.
DASHBOARD_URL="http://localhost:3000"
